# Env cho container backend (Laravel). Copy thành env/backend.env
# Lưu ý: host DB/Redis là TÊN SERVICE trong docker-compose (mysql, redis).
APP_NAME="Anh Ngu"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=anh_ngu
DB_USERNAME=anhngu
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local
MAIL_MAILER=log
